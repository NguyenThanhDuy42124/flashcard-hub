# Copy this file to backend/.env.mysql, then fill your real MySQL values.
# backend/database.py will auto-load backend/.env.mysql if present.

# Optional direct URL (highest priority)
# DATABASE_URL=mysql+pymysql://username:password@127.0.0.1:3306/flashcard_hub?charset=utf8mb4

# MySQL split fields (used when DATABASE_URL is empty)
MYSQL_ENDPOINT=103.228.36.238:3307
# MYSQL_HOST=103.228.36.238
# MYSQL_PORT=3307
MYSQL_DATABASE=sample_flashcard_db
MYSQL_USER=sample_user
MYSQL_PASSWORD=sample_password
MYSQL_CHARSET=utf8mb4

# Optional backend host/port
HOST=0.0.0.0
PORT=8000
RELOAD=True
